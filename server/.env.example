# ───── Server ─────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ───── MongoDB ────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/creditx
# Atlas:   mongodb+srv://<user>:<pass>@<cluster>/creditx?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/creditx

# ───── JWT ────────────────────────────────────────────────
# Use a strong random string in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=60s
JWT_REFRESH_EXPIRES_IN=7d

# ───── CORS ───────────────────────────────────────────────
# Origin of the Vite dev server
CORS_ORIGIN=http://localhost:5173
